FROM python:3.12-slim

ARG VERSION
ENV PYTHONOPTIMIZE=1 ROOT_PATH=/api ENV=dev CONFIG_FILE=/etc/basic-service/config.json VERSION=${VERSION}
WORKDIR /data

ADD https://github.com/wwricu/basic-service/releases/download/snapshot/wwricu-${VERSION}-py3-none-any.whl .

RUN pip3 install --disable-pip-version-check --no-cache-dir wwricu-${VERSION}-py3-none-any.whl && rm wwricu-${VERSION}-py3-none-any.whl \
&& ln -sf /usr/share/zoneinfo/Asia/Shanghai /etc/localtime && echo 'Asia/Shanghai' > /etc/timezone

CMD ["uvicorn", "wwricu.main:app", "--host", "0.0.0.0", "--no-access-log"]
